<Window x:Class="BattlePixel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BattlePixel" 
        Width="800" 
        Height="600"
        MinWidth="800" 
        MinHeight="600"
        MaxWidth="800" 
        MaxHeight="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded">

    <Grid>
        <!-- Игровая зона 800x600 -->
        <Grid Width="800" Height="600" ClipToBounds="True">

            <Canvas x:Name="WorldLayer" Width="1664" Height="600" HorizontalAlignment="Left">
                <Canvas.RenderTransform>
                    <TranslateTransform x:Name="WorldTransform"/>
                </Canvas.RenderTransform>

                <Image x:Name="BackgroundImage"
               Source="Assets/Backgrounds/GrassLand_Background_Guide.png"
               Width="1664"
               Height="600"
               Stretch="Fill"
               Canvas.Left="0"
               Canvas.Top="0"/>

                <Canvas x:Name="GameCanvas" 
                Background="Transparent" 
                Width="1664" 
                Height="600"
                Canvas.Left="0"
                Canvas.Top="0"/>
            </Canvas>

        </Grid>

        <!-- HUD -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="10,6,0,0"
                    IsHitTestVisible="False">
            <TextBlock x:Name="CoinsText"
                       Text="Coins: 0"
                       Foreground="Gold"
                       FontSize="16"
                       FontWeight="Bold"/>
            <TextBlock x:Name="LevelText"
                       Text="  |  Level: 1"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"/>
        </StackPanel>

        <!-- Инвентарь (I) -->
        <Border x:Name="InventoryOverlay"
        Background="#AA000000"
        Visibility="Collapsed">
            <Border Background="#FF2B2B2B"
            BorderBrush="#FF111111"
            BorderThickness="3"
            CornerRadius="4"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="20">
                <StackPanel>
                    <TextBlock Text="Инвентарь"
                       Foreground="#FFDDAA00"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal">

                        <!-- Ячейки предметов: 2x3 -->
                        <UniformGrid x:Name="InventoryGrid"
                             Columns="2" Rows="3"
                             Width="112" Height="168"
                             Margin="0,0,20,0"/>

                        <!-- Окно с персонажем -->
                        <Border Background="#FF1E1E1E"
                        BorderBrush="#FF111111"
                        BorderThickness="2"
                        Width="260" Height="260">
                            <Canvas x:Name="InventoryCharacterCanvas"
                            Width="260" Height="260"
                            ClipToBounds="True"/>
                        </Border>

                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Древо навыков -->
        <Border x:Name="SkillTreeOverlay"
                Background="#AA000000"
                Visibility="Collapsed">
            <Border Background="#FF2B2B2B"
                    BorderBrush="#FF111111"
                    BorderThickness="3"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="Древо навыков"
                               Foreground="#FFDDAA00"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <Canvas x:Name="SkillTreeCanvas"
                            Width="520" Height="520"/>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
