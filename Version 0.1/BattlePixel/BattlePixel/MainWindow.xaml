<Window x:Class="BattlePixel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BattlePixel" 
        Width="800" 
        Height="600"
        MinWidth="800" 
        MinHeight="600"
        MaxWidth="800" 
        MaxHeight="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded">

    <Grid>
        <!-- Контейнер с фиксированным размером окна, обрезает всё что вылезает -->
        <Grid Width="800" Height="600" ClipToBounds="True">

            <!-- Слой для фона и карты, который в будущем будет двигаться при скролле -->
            <Canvas x:Name="WorldLayer" Width="1664" Height="600">

                <Image x:Name="BackgroundImage"
                       Source="C:\Users\black\source\repos\BattlePixel\BattlePixel\Assets\Backgrounds\GrassLand_Background_Guide.png"
                       Width="1664"
                       Height="600"
                       Stretch="Fill"
                       Canvas.Left="0"
                       Canvas.Top="0"/>

                <Canvas x:Name="GameCanvas" 
                        Background="Transparent" 
                        Width="1664" 
                        Height="600" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="-865" />
            </Canvas>

        </Grid>

        <!-- Оверлей инвентаря -->
        <Border x:Name="InventoryOverlay"
                Background="#AA000000"
                Visibility="Collapsed">
            <Border Background="#FF2B2B2B"
                    BorderBrush="#FF111111"
                    BorderThickness="3"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="20">
                <StackPanel Orientation="Horizontal">

                    <!-- Сетка предметов: 2 столбца x 3 строки -->
                    <UniformGrid x:Name="InventoryGrid"
                                 Columns="2" Rows="3"
                                 Width="112" Height="168"
                                 Margin="0,0,20,0"/>

                    <!-- Окно с персонажем -->
                    <Border Background="#FF1E1E1E"
                            BorderBrush="#FF111111"
                            BorderThickness="2"
                            Width="260" Height="260">
                        <Canvas x:Name="InventoryCharacterCanvas"
                                Width="260" Height="260"
                                ClipToBounds="True"/>
                    </Border>

                </StackPanel>
            </Border>
        </Border>

        <!-- Оверлей древа навыков -->
        <Border x:Name="SkillTreeOverlay"
                Background="#AA000000"
                Visibility="Collapsed">
            <Border Background="#FF2B2B2B"
                    BorderBrush="#FF111111"
                    BorderThickness="3"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="10">
                <Canvas x:Name="SkillTreeCanvas"
                        Width="520" Height="520"/>
            </Border>
        </Border>

    </Grid>

</Window>