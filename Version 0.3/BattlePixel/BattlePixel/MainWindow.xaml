<Window x:Class="BattlePixel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BattlePixel"
        Width="800"
        Height="600"
        MinWidth="800"
        MinHeight="600"
        MaxWidth="800"
        MaxHeight="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded">
    <Grid>
        <!-- Игровая область -->
        <Grid Width="800" Height="600" ClipToBounds="True">
            
            <!-- Основной слой мира с возможностью сдвига (камера) -->
            <Canvas x:Name="WorldLayer" Width="1664" Height="600" HorizontalAlignment="Left">
                <Canvas.RenderTransform>
                    <TranslateTransform x:Name="WorldTransform"/>
                </Canvas.RenderTransform>

                <!-- Фоновое изображение уровня -->
                <Image x:Name="BackgroundImage"
                       Source="Assets/Backgrounds/GrassLand_Background_Guide.png"
                       Width="1664" Height="600"
                       Stretch="Fill"
                       Canvas.Left="0" Canvas.Top="0"/>

                <!-- Основной канвас для всех игровых объектов -->
                <Canvas x:Name="GameCanvas"
                        Background="Transparent"
                        Width="1664" Height="600"
                        Canvas.Left="0" Canvas.Top="0"/>
            </Canvas>
        </Grid>

        <!-- HUD -->
        <!-- В левом верхнем углу -->
        <StackPanel x:Name="HudPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="10,6,0,0"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
            <TextBlock x:Name="CoinsText" Text="Coins: 0"
                       Foreground="Gold" FontSize="16" FontWeight="Bold"/>
            <TextBlock x:Name="LevelText" Text=" | Level: 1"
                       Foreground="White" FontSize="16" FontWeight="Bold"/>
        </StackPanel>

        <!-- ГЛАВНОЕ МЕНЮ -->
        <!-- Основное меню при запуске игры -->
        <Border x:Name="MainMenuOverlay" Background="Transparent" Visibility="Visible">
            <!-- Фон -->
            <Grid>
                <Image Source="Assets/Backgrounds/GrassLand_Background_Guide.png"
                       Stretch="UniformToFill"/>
                <!-- Затемнение -->
                <Rectangle Fill="#99000000"/>

                <!-- Панель меню -->
                <Border Background="#FF2B2B2B"
                        BorderBrush="#FF111111"
                        BorderThickness="3"
                        CornerRadius="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="32,24">
                    <StackPanel Width="220">
                        <TextBlock Text="BATTLEPIXEL"
                                   Foreground="#FFDDAA00"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,24"/>
                        <Button x:Name="BtnNewGame" Content="Новая игра"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="BtnNewGame_Click"/>
                        <Button x:Name="BtnContinue" Content="Продолжить"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="BtnContinue_Click"/>
                        <Button x:Name="BtnMainSettings" Content="Настройки"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="BtnMainSettings_Click"/>
                        <Button x:Name="BtnExit" Content="Выход из игры"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="BtnExit_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ПАУЗА -->
        <!-- Окно паузы -->
        <Border x:Name="PauseOverlay" Background="#AA000000" Visibility="Collapsed">
            <Border Background="#FF2B2B2B"
                    BorderBrush="#FF111111"
                    BorderThickness="3"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="32,24">
                <StackPanel Width="220">
                    <TextBlock Text="ПАУЗА"
                               Foreground="#FFDDAA00"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <Button Content="Продолжить"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="BtnPauseResume_Click"/>
                    <Button Content="Настройки"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="BtnPauseSettings_Click"/>
                    <Button Content="Начать заново"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="BtnPauseRestart_Click"/>
                    <Button Content="Выход из игры"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="BtnPauseExit_Click"/>
                </StackPanel>
            </Border>
        </Border>

        <!--  СМЕРТЬ ИГРОКА  -->
        <!-- Экран смерти игрока -->
        <Border x:Name="DeathOverlay" Background="#AA000000" Visibility="Collapsed">
            <Border Background="#FF2B2B2B"
                    BorderBrush="#FF111111"
                    BorderThickness="3"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="32,24">
                <StackPanel Width="220">
                    <TextBlock Text="ВЫ ПОГИБЛИ"
                               Foreground="#FFDD2200"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <Button Content="Перерождение"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="BtnDeathRebirth_Click"/>
                    <Button Content="Начать заново"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="BtnDeathRestart_Click"/>
                    <Button Content="Выйти из игры"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="BtnDeathExit_Click"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- НАСТРОЙКИ -->
        <!-- Окно настроек -->
        <Border x:Name="SettingsOverlay" Background="#AA000000" Visibility="Collapsed">
            <Border Background="#FF2B2B2B"
                    BorderBrush="#FF111111"
                    BorderThickness="3"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="32,24">
                <StackPanel Width="300">
                    <TextBlock Text="НАСТРОЙКИ"
                               Foreground="#FFDDAA00"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Громкость музыки -->
                    <TextBlock Text="Громкость музыки"
                               Foreground="#FFCCCCCC"
                               FontSize="13"
                               Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="MusicSlider"
                                Grid.Column="0"
                                Minimum="0" Maximum="100"
                                Value="50"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="MusicSlider_ValueChanged"/>
                        <TextBlock x:Name="MusicPct"
                                   Grid.Column="1"
                                   Text="50%"
                                   Foreground="#FFDDAA00"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Громкость звуков -->
                    <TextBlock Text="Громкость звуков"
                               Foreground="#FFCCCCCC"
                               FontSize="13"
                               Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SoundSlider"
                                Grid.Column="0"
                                Minimum="0" Maximum="100"
                                Value="50"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="SoundSlider_ValueChanged"/>
                        <TextBlock x:Name="SoundPct"
                                   Grid.Column="1"
                                   Text="50%"
                                   Foreground="#FFDDAA00"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Grid>

                    <Button Content="Назад"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="BtnSettingsBack_Click"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- ИНВЕНТАРЬ -->
        <!-- Окно инвентаря -->
        <Border x:Name="InventoryOverlay" Background="#AA000000" Visibility="Collapsed">
            <Border Background="#FF2B2B2B"
                    BorderBrush="#FF111111"
                    BorderThickness="3"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Инвентарь"
                               Foreground="#FFDDAA00"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        
                        <!-- Сетка для предметов инвентаря -->
                        <UniformGrid x:Name="InventoryGrid"
                                     Columns="2" Rows="3"
                                     Width="112" Height="168"
                                     Margin="0,0,20,0"/>

                        <!-- Отображение персонажа в экипировке -->
                        <Border Background="#FF1E1E1E"
                                BorderBrush="#FF111111"
                                BorderThickness="2"
                                Width="260" Height="260">
                            <Canvas x:Name="InventoryCharacterCanvas"
                                    Width="260" Height="260"
                                    ClipToBounds="True"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ДРЕВО НАВЫКОВ -->
        <!-- Окно дерева навыков -->
        <Border x:Name="SkillTreeOverlay" Background="#AA000000" Visibility="Collapsed">
            <Border Background="#FF2B2B2B"
                    BorderBrush="#FF111111"
                    BorderThickness="3"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="Древо навыков"
                               Foreground="#FFDDAA00"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <!-- Холст для отрисовки дерева навыков -->
                    <Canvas x:Name="SkillTreeCanvas" Width="520" Height="520"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>